# Copy this file to .env and fill in the values for your setup.
# docker-compose.yaml reads .env automatically for variable substitution.

# ── Frontend URLs (baked into the CRA build via Docker build args) ─────────────
# REACT_APP_API_BASE=http://localhost:8000
# REACT_APP_BACKEND_URL=http://localhost:5001

# ── AI Provider ────────────────────────────────────────────────────────────────
# Choose one profile below and uncomment it.

# Profile A — Ollama Cloud (dev-friendly, no local Ollama required)
#   Get an API key at https://ollama.com/settings/keys
#   Model tags: https://ollama.com/library
AI_PROVIDER=ollama_cloud
OLLAMA_API_KEY=your-ollama-cloud-api-key
MODEL_NAME=gemma3:4b

# Profile B — Local Ollama (full privacy, requires `ollama serve` on the host)
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# MODEL_NAME=gemma3:1b

# Profile C — OpenAI-compatible endpoint
# AI_PROVIDER=openai
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=your-openai-api-key
# MODEL_NAME=gpt-4o-mini
